# =============================================================================
# flow-matrx backend — environment variable template
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================


# =============================================================================
# App
# =============================================================================
APP_ENV=development               # development | staging | production
DEBUG=false
SECRET_KEY=change-me-in-production-use-a-long-random-string

# JSON array of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:5173"]

# Absolute path to the backend package root (used by tooling / db generate.py)
MATRX_PYTHON_ROOT=/absolute/path/to/flow-matrx/backend

# Cross-project roots — used by matrx tooling that spans multiple projects
ADMIN_PYTHON_ROOT=/absolute/path/to/admin-project/backend
ADMIN_TS_ROOT=/absolute/path/to/admin-project/frontend

# Optional: bypass git working-tree check when writing generated schema files
# MATRX_SAVE_DIRECT=true


# =============================================================================
# Primary Database  (env_prefix: FLOW_MATRX_DB_)
# Used by matrx-orm register_database_from_env(env_prefix="FLOW_MATRX_DB")
# =============================================================================
FLOW_MATRX_DB_HOST=db.your-project.supabase.co
FLOW_MATRX_DB_PORT=5432
FLOW_MATRX_DB_NAME=postgres
FLOW_MATRX_DB_USER=postgres
FLOW_MATRX_DB_PASSWORD=your-db-password
FLOW_MATRX_DB_PROTOCOL=postgresql

# Supabase project credentials (for direct Supabase client usage)
FLOW_MATRX_DB_PROJECT_URL=https://your-project.supabase.co
FLOW_MATRX_DB_PUBLISHABLE_KEY=sb_publishable_...
FLOW_MATRX_DB_SECRET_KEY=sb_secret_...
FLOW_MATRX_DB_DIRECT_CONNECTION_STRING=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres


# =============================================================================
# Secondary Database  (env_prefix: FLOW_MATRX_DB2_)
# Separate Postgres instance for analytical/reporting workloads, read replica,
# or any second database your app needs.
# =============================================================================
FLOW_MATRX_DB2_HOST=db.your-second-project.supabase.co
FLOW_MATRX_DB2_PORT=5432
FLOW_MATRX_DB2_NAME=postgres
FLOW_MATRX_DB2_USER=postgres
FLOW_MATRX_DB2_PASSWORD=your-db2-password
FLOW_MATRX_DB2_PROTOCOL=postgresql

# Supabase project credentials for secondary DB (if applicable)
FLOW_MATRX_DB2_PROJECT_URL=https://your-second-project.supabase.co
FLOW_MATRX_DB2_PUBLISHABLE_KEY=sb_publishable_...
FLOW_MATRX_DB2_SECRET_KEY=sb_secret_...
FLOW_MATRX_DB2_DIRECT_CONNECTION_STRING=postgresql://postgres:password@db.your-second-project.supabase.co:5432/postgres


# =============================================================================
# Supabase Auth  (env_prefix: SUPABASE_)
# Used by the JWT verification middleware.
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...


# =============================================================================
# Redis  (env_prefix: REDIS_)
# Used by ARQ background task queue and pub/sub.
# =============================================================================
REDIS_URL=redis://localhost:6379


# =============================================================================
# LLM Providers
# All keys are optional — only configure the providers you use.
# Keys are stored as SecretStr and never appear in logs or tracebacks.
# =============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...
TOGETHER_API_KEY=tgp_v1_...
CEREBRAS_API_KEY=csk-...
XAI_API_KEY=xai-...


# =============================================================================
# Logging  (env_prefix: LOG_)
# =============================================================================
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json         # json | console  (use console for local dev)


# =============================================================================
# Notes on directory configuration
# =============================================================================
# The following project directories are computed automatically from
# MATRX_PYTHON_ROOT and created at startup — they are NOT set via env vars:
#
#   {MATRX_PYTHON_ROOT}/tmp            settings.dirs.temp_dir
#   {MATRX_PYTHON_ROOT}/logs           settings.dirs.logs_dir
#   {MATRX_PYTHON_ROOT}/reports        settings.dirs.reports_dir
#   {MATRX_PYTHON_ROOT}/sample_data    settings.dirs.sample_data_dir
